# Handle line endings automatically for all text files
* text=auto

# Explicitly set line endings for common files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.md text eol=lf

# Treat images and binaries as binary (no diffing)
*.png binary
*.ico binary

# Mark README.md as documentation
README.md linguist-documentation

# If you want to force language detection for GitHub linguist
*.js linguist-language=JavaScript
*.css linguist-language=CSS
*.html linguist-language=HTML
